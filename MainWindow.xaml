<infrastructure:LocalizedWindow x:Class="WordFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Views="clr-namespace:WordFlow.Views"
        xmlns:res="clr-namespace:WordFlow.Resources.Strings"
        xmlns:infrastructure="clr-namespace:WordFlow.Infrastructure"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.MainWindow_Title}"
        infrastructure:LocalizeExtension.ResourceKey="MainWindow_Title"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="600" MinHeight="400">
    <Grid>
        <!-- 主界面 - 仪表盘风格 -->
        <Grid x:Name="MainContent" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部导航栏 -->
            <Border Grid.Row="0" Background="#1a1a2e" Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧：Logo 和标题 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WordFlow" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="{x:Static res:Strings.MW_OfflineASR}" Foreground="#00d4aa" FontSize="13" FontWeight="Medium"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   infrastructure:LocalizeExtension.ResourceKey="MW_OfflineASR"/>
                    </StackPanel>
                    
                    <!-- 中间：功能按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0">
                        <Button Content="{x:Static res:Strings.MW_ModelManager}" Click="ModelManagerButton_Click" 
                                Padding="16,8" Margin="0,0,12,0" MinWidth="90" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="{x:Static res:Strings.MW_ModelManager_Tooltip}"
                                infrastructure:LocalizeExtension.ResourceKey="MW_ModelManager">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button Content="{x:Static res:Strings.MW_PersonalDictionary}" Click="VocabularyButton_Click" 
                                Padding="16,8" Margin="0,0,12,0" MinWidth="90" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="{x:Static res:Strings.MW_PersonalDictionary_Tooltip}"
                                infrastructure:LocalizeExtension.ResourceKey="MW_PersonalDictionary">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button Content="{x:Static res:Strings.MW_Settings}" Click="SettingsButton_Click" 
                                Padding="16,8" MinWidth="70" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="{x:Static res:Strings.MW_Settings_Tooltip}"
                                infrastructure:LocalizeExtension.ResourceKey="MW_Settings">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    
                    <!-- 右侧：状态显示 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <!-- 模型连接状态（合并显示） -->
                        <Ellipse x:Name="ModelStatusIndicator" Width="10" Height="10" Fill="Gray" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ModelStatusText" Text="{x:Static res:Strings.MW_Status_NotConnected}" Foreground="White" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,15,0"
                                   infrastructure:LocalizeExtension.ResourceKey="MW_Status_NotConnected"/>
                        <!-- 状态文本 -->
                        <TextBlock x:Name="StatusText" Text="{x:Static res:Strings.MW_Status_Ready}" Foreground="#AAAAAA" FontSize="13"
                                   VerticalAlignment="Center"
                                   infrastructure:LocalizeExtension.ResourceKey="MW_Status_Ready"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#f5f5f7">
                <StackPanel Margin="20">
                    
                    <!-- 录音控制卡片 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.MW_StartRecording}" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_StartRecording"/>
                                <TextBlock Text="{x:Static res:Strings.MW_RecordHint}" FontSize="14" Foreground="#666"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_RecordHint"/>
                                <TextBlock x:Name="HotkeyHintText" Text="{x:Static res:Strings.MW_HotkeyHint}" 
                                           FontSize="13" Foreground="#1a73e8" Margin="0,8,0,0" FontWeight="Medium"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_HotkeyHint"/>
                            </StackPanel>
                            
                            <Button x:Name="RecordButton" Click="RecordButton_Click" 
                                    Grid.Column="1" Padding="40,18" FontSize="17" FontWeight="Medium"
                                    Cursor="Hand" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1565c0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#1565c0" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0d47a1"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#1565c0" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#08348a"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#1565c0" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="RecordButtonIndicator" Width="12" Height="12" 
                                             Fill="White" Margin="0,0,12,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="RecordButtonText" Text="{x:Static res:Strings.MW_PressToRecord}" 
                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                               infrastructure:LocalizeExtension.ResourceKey="MW_PressToRecord"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 统计卡片行 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 今日字数 -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.MW_TodayInput}" FontSize="13" Foreground="#666"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_TodayInput"/>
                                <TextBlock x:Name="TodayCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                           Foreground="#1a73e8" Margin="0,8,0,0"/>
                                <TextBlock Text="{x:Static res:Strings.MW_Characters}" FontSize="12" Foreground="#999"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_Characters"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 累计字数 -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.MW_TotalInput}" FontSize="13" Foreground="#666"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_TotalInput"/>
                                <TextBlock x:Name="TotalCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                           Foreground="#34a853" Margin="0,8,0,0"/>
                                <TextBlock Text="{x:Static res:Strings.MW_Characters}" FontSize="12" Foreground="#999"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_Characters"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 节省时间 -->
                        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.MW_SavedTime}" FontSize="13" Foreground="#666"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_SavedTime"/>
                                <TextBlock x:Name="SavedTimeText" Text="0 分钟" FontSize="28" FontWeight="Bold" 
                                           Foreground="#fbbc04" Margin="0,8,0,0"/>
                                <TextBlock Text="{x:Static res:Strings.MW_Estimated}" FontSize="12" Foreground="#999"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_Estimated"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 准确率 -->
                        <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.MW_Accuracy}" FontSize="13" Foreground="#666"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_Accuracy"/>
                                <TextBlock x:Name="AccuracyText" Text="--" FontSize="28" FontWeight="Bold" 
                                           Foreground="#ea4335" Margin="0,8,0,0"/>
                                <TextBlock Text="{x:Static res:Strings.MW_BasedOnCorrections}" FontSize="12" Foreground="#999"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_BasedOnCorrections"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 新手引导区 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{x:Static res:Strings.MW_NewbieGuide}" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"
                                       infrastructure:LocalizeExtension.ResourceKey="MW_NewbieGuide"/>
                            
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="{x:Static res:Strings.MW_HowToUseTitle}" FontSize="15" FontWeight="Medium" 
                                           Foreground="#333" Margin="0,0,0,10"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_HowToUseTitle"/>
                                <TextBlock Text="{x:Static res:Strings.MW_HowToUse_Step1}" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_HowToUse_Step1"/>
                                <TextBlock Text="{x:Static res:Strings.MW_HowToUse_Step2}" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_HowToUse_Step2"/>
                                <TextBlock Text="{x:Static res:Strings.MW_HowToUse_Step3}" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_HowToUse_Step3"/>
                                <TextBlock Text="{x:Static res:Strings.MW_HowToUse_Step4}" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"
                                           infrastructure:LocalizeExtension.ResourceKey="MW_HowToUse_Step4"/>
                            </StackPanel>
                            
                            <Border Background="#fff8e1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="{x:Static res:Strings.MW_TipsTitle}" FontSize="14" FontWeight="Bold" 
                                               Foreground="#f57c00" Margin="0,0,0,5"
                                               infrastructure:LocalizeExtension.ResourceKey="MW_TipsTitle"/>
                                    <TextBlock Text="{x:Static res:Strings.MW_Tip1}" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"
                                               infrastructure:LocalizeExtension.ResourceKey="MW_Tip1"/>
                                    <TextBlock Text="{x:Static res:Strings.MW_Tip2}" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"
                                               infrastructure:LocalizeExtension.ResourceKey="MW_Tip2"/>
                                    <TextBlock Text="{x:Static res:Strings.MW_Tip3}" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"
                                               infrastructure:LocalizeExtension.ResourceKey="MW_Tip3"/>
                                    <TextBlock Text="{x:Static res:Strings.MW_Tip4}" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"
                                               infrastructure:LocalizeExtension.ResourceKey="MW_Tip4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 文字输入说明 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{x:Static res:Strings.MW_InputExplanationTitle}" FontSize="18" FontWeight="Bold" 
                                       Foreground="#333" Margin="0,0,0,10"
                                       infrastructure:LocalizeExtension.ResourceKey="MW_InputExplanationTitle"/>
                            <TextBlock Text="{x:Static res:Strings.MW_InputExplanationText}" 
                                       FontSize="14" Foreground="#666" Margin="0,5" TextWrapping="Wrap"
                                       infrastructure:LocalizeExtension.ResourceKey="MW_InputExplanationText"/>
                            <TextBlock Text="{x:Static res:Strings.MW_HistoryHint}" 
                                       FontSize="14" Foreground="#666" Margin="0,5" TextWrapping="Wrap"
                                       infrastructure:LocalizeExtension.ResourceKey="MW_HistoryHint"/>
                        </StackPanel>
                    </Border>

                    <!-- 进度条（隐藏，用于显示处理状态） -->
                    <ProgressBar x:Name="StatusProgressBar" Height="4" 
                                 Visibility="Collapsed" IsIndeterminate="True"
                                 Margin="0,10,0,0"/>
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- 个人词典页面（默认隐藏） -->
        <Views:VocabularyPage x:Name="VocabularyPageControl" 
                              Visibility="Collapsed"
                              BackRequested="OnVocabularyPageBackRequested"/>
    </Grid>
</infrastructure:LocalizedWindow>
