<Window x:Class="WordFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Views="clr-namespace:WordFlow.Views"
        mc:Ignorable="d"
        Title="WordFlow - 智能语音输入" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="600" MinHeight="400">
    <Grid>
        <!-- 主界面 - 仪表盘风格 -->
        <Grid x:Name="MainContent" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Background="#1a1a2e" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WordFlow" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="  ·  个人离线语音输入" Foreground="#00d4aa" FontSize="14" 
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="Medium"/>
                        <Border Background="#00d4aa" CornerRadius="3" Padding="6,2" Margin="15,0,0,0">
                            <TextBlock Text="离线" Foreground="#1a1a2e" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="RecordIndicator" Width="12" Height="12" Fill="Gray" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusText" Text="就绪" Foreground="#AAAAAA" 
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock x:Name="ModelStatusText" Text="模型：未连接" Foreground="Gray" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#f5f5f7">
                <StackPanel Margin="20">
                    
                    <!-- 录音控制卡片 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="开始录音" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8"/>
                                <TextBlock Text="按住快捷键说话，松开自动识别" FontSize="14" Foreground="#666"/>
                                <TextBlock x:Name="HotkeyHintText" Text="当前快捷键：按住 ` 键（ESC 下方）" 
                                           FontSize="13" Foreground="#1a73e8" Margin="0,8,0,0" FontWeight="Medium"/>
                            </StackPanel>
                            
                            <Button x:Name="RecordButton" Click="RecordButton_Click" 
                                    Grid.Column="1" Padding="30,15" FontSize="16"
                                    Background="#1a73e8" Foreground="White" BorderThickness="0"
                                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="RecordButtonIndicator" Width="10" Height="10" 
                                             Fill="White" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="RecordButtonText" Text="按住 CapsLock 说话" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 统计卡片行 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 今日字数 -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="今日输入" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="TodayCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                           Foreground="#1a73e8" Margin="0,8,0,0"/>
                                <TextBlock Text="字" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 累计字数 -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="累计输入" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="TotalCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                           Foreground="#34a853" Margin="0,8,0,0"/>
                                <TextBlock Text="字" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 节省时间 -->
                        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="节省时间" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="SavedTimeText" Text="0 分钟" FontSize="28" FontWeight="Bold" 
                                           Foreground="#fbbc04" Margin="0,8,0,0"/>
                                <TextBlock Text="估算值" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 准确率 -->
                        <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="识别准确率" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="AccuracyText" Text="--" FontSize="28" FontWeight="Bold" 
                                           Foreground="#ea4335" Margin="0,8,0,0"/>
                                <TextBlock Text="基于修正统计" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 快速操作区 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="快速操作" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>
                            <WrapPanel>
                                <Button Content="🧠 模型管理" Click="ModelManagerButton_Click" 
                                        Padding="15,10" Margin="0,0,10,10" MinWidth="120"
                                        Background="#f0f4ff" Foreground="#1a73e8" BorderThickness="0"
                                        Cursor="Hand" ToolTip="管理语音模型（切换/下载/删除）"/>
                                <Button Content="📁 导入音频" Click="ImportAudioButton_Click" 
                                        Padding="15,10" Margin="0,0,10,10" MinWidth="120"
                                        Background="#f0f4ff" Foreground="#1a73e8" BorderThickness="0"
                                        Cursor="Hand" ToolTip="导入 WAV 文件进行识别"/>
                                <Button Content="📚 个人词典" Click="VocabularyButton_Click" 
                                        Padding="15,10" Margin="0,0,10,10" MinWidth="120"
                                        Background="#f0f4ff" Foreground="#1a73e8" BorderThickness="0"
                                        Cursor="Hand" ToolTip="管理个人词典和热词"/>
                                <Button Content="⚙️ 设置" Click="SettingsButton_Click" 
                                        Padding="15,10" Margin="0,0,10,10" MinWidth="120"
                                        Background="#f0f4ff" Foreground="#1a73e8" BorderThickness="0"
                                        Cursor="Hand" ToolTip="热键和启动设置"/>
                                <Button Content="🔗 连接服务" Click="ConnectButton_Click" 
                                        Padding="15,10" Margin="0,0,10,10" MinWidth="120"
                                        Background="#f0f4ff" Foreground="#1a73e8" BorderThickness="0"
                                        Cursor="Hand" ToolTip="连接/重连 ASR 服务"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 新手引导区 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="新手引导" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>
                            
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="📌 如何使用语音输入" FontSize="15" FontWeight="Medium" 
                                           Foreground="#333" Margin="0,0,0,10"/>
                                <TextBlock Text="1. 确保已安装语音模型（首次使用请在「模型管理」中下载）" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="2. 点击需要输入文字的窗口（如记事本、Word 等）" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="3. 按住 ` 键 或 右 Alt 键说话，说完松开" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="4. 文字将自动输入到您选择的窗口中" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <Border Background="#fff8e1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="💡 提示" FontSize="14" FontWeight="Bold" 
                                               Foreground="#f57c00" Margin="0,0,0,5"/>
                                <TextBlock Text="• 可在「设置」中更改快捷键（支持 ` 键 或 右 Alt）" 
                                           FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 录音时请确保周围环境相对安静" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 识别结果会自动保存到「历史记录」" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 专业词汇可在「个人词典」中添加，提高识别准确率" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 编辑器已移除 - 文字将直接输入到目标窗口 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📝 文字输入说明" FontSize="18" FontWeight="Bold" 
                                       Foreground="#333" Margin="0,0,0,10"/>
                            <TextBlock Text="文字将直接输入到您选择的目标窗口（如记事本、Word 等）" 
                                       FontSize="14" Foreground="#666" Margin="0,5" TextWrapping="Wrap"/>
                            <TextBlock Text="无需在此处查看，如需查看历史记录，请使用「个人词典」功能" 
                                       FontSize="14" Foreground="#666" Margin="0,5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 进度条（隐藏，用于显示处理状态） -->
                    <ProgressBar x:Name="StatusProgressBar" Height="4" 
                                 Visibility="Collapsed" IsIndeterminate="True"
                                 Margin="0,10,0,0"/>
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- 个人词典页面（默认隐藏） -->
        <Views:VocabularyPage x:Name="VocabularyPageControl" 
                              Visibility="Collapsed"
                              BackRequested="OnVocabularyPageBackRequested"/>
    </Grid>
</Window>
