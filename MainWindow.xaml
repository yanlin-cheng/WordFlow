<Window x:Class="WordFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Views="clr-namespace:WordFlow.Views"
        mc:Ignorable="d"
        Title="WordFlow - 智能语音输入" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="600" MinHeight="400">
    <Grid>
        <!-- 主界面 - 仪表盘风格 -->
        <Grid x:Name="MainContent" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部导航栏 -->
            <Border Grid.Row="0" Background="#1a1a2e" Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧：Logo 和标题 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WordFlow" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="离线语音输入" Foreground="#00d4aa" FontSize="13" FontWeight="Medium"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    
                    <!-- 中间：功能按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0">
                        <Button Content="模型管理" Click="ModelManagerButton_Click" 
                                Padding="16,8" Margin="0,0,12,0" MinWidth="90" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="管理语音模型（切换/下载/删除）">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button Content="个人词典" Click="VocabularyButton_Click" 
                                Padding="16,8" Margin="0,0,12,0" MinWidth="90" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="管理个人词典和热词">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button Content="导入音频" Click="ImportAudioButton_Click" 
                                Padding="16,8" Margin="0,0,12,0" MinWidth="90" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="导入 WAV 文件进行识别">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button Content="设置" Click="SettingsButton_Click" 
                                Padding="16,8" MinWidth="70" FontSize="14" FontWeight="Medium"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                Cursor="Hand" ToolTip="热键和启动设置">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a4a"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1a1a2a"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    
                    <!-- 右侧：状态显示 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <!-- 模型连接状态（合并显示） -->
                        <Ellipse x:Name="ModelStatusIndicator" Width="10" Height="10" Fill="Gray" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ModelStatusText" Text="未连接" Foreground="White" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <!-- 状态文本 -->
                        <TextBlock x:Name="StatusText" Text="就绪" Foreground="#AAAAAA" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#f5f5f7">
                <StackPanel Margin="20">
                    
                    <!-- 录音控制卡片 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="开始录音" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8"/>
                                <TextBlock Text="按住快捷键说话，松开自动识别" FontSize="14" Foreground="#666"/>
                                <TextBlock x:Name="HotkeyHintText" Text="当前快捷键：按住 ` 键（ESC 下方）" 
                                           FontSize="13" Foreground="#1a73e8" Margin="0,8,0,0" FontWeight="Medium"/>
                            </StackPanel>
                            
                            <Button x:Name="RecordButton" Click="RecordButton_Click" 
                                    Grid.Column="1" Padding="40,18" FontSize="17" FontWeight="Medium"
                                    Cursor="Hand" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1565c0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#1565c0" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0d47a1"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#1565c0" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#08348a"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#1565c0" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="RecordButtonIndicator" Width="12" Height="12" 
                                             Fill="White" Margin="0,0,12,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="RecordButtonText" Text="按住 ` 键说话" 
                                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 统计卡片行 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 今日字数 -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="今日输入" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="TodayCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                           Foreground="#1a73e8" Margin="0,8,0,0"/>
                                <TextBlock Text="字" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 累计字数 -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="累计输入" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="TotalCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                           Foreground="#34a853" Margin="0,8,0,0"/>
                                <TextBlock Text="字" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 节省时间 -->
                        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="节省时间" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="SavedTimeText" Text="0 分钟" FontSize="28" FontWeight="Bold" 
                                           Foreground="#fbbc04" Margin="0,8,0,0"/>
                                <TextBlock Text="估算值" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 准确率 -->
                        <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="20"
                                BorderBrush="#e0e0e0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="识别准确率" FontSize="13" Foreground="#666"/>
                                <TextBlock x:Name="AccuracyText" Text="--" FontSize="28" FontWeight="Bold" 
                                           Foreground="#ea4335" Margin="0,8,0,0"/>
                                <TextBlock Text="基于修正统计" FontSize="12" Foreground="#999"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 新手引导区 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="新手引导" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>
                            
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="📌 如何使用语音输入" FontSize="15" FontWeight="Medium" 
                                           Foreground="#333" Margin="0,0,0,10"/>
                                <TextBlock Text="1. 确保已安装语音模型（首次使用请在「模型管理」中下载）" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="2. 点击需要输入文字的窗口（如记事本、Word 等）" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="3. 按住 ` 键 或 右 Alt 键说话，说完松开" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="4. 文字将自动输入到您选择的窗口中" 
                                           FontSize="13" Foreground="#666" Margin="0,3" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <Border Background="#fff8e1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="💡 提示" FontSize="14" FontWeight="Bold" 
                                               Foreground="#f57c00" Margin="0,0,0,5"/>
                                    <TextBlock Text="• 可在「设置」中更改快捷键（支持 ` 键 或 右 Alt）" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 录音时请确保周围环境相对安静" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 识别结果会自动保存到「历史记录」" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Text="• 专业词汇可在「个人词典」中添加，提高识别准确率" 
                                               FontSize="13" Foreground="#666" Margin="0,2" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 文字输入说明 -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                            BorderBrush="#e0e0e0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📝 文字输入说明" FontSize="18" FontWeight="Bold" 
                                       Foreground="#333" Margin="0,0,0,10"/>
                            <TextBlock Text="文字将直接输入到您选择的目标窗口（如记事本、Word 等）" 
                                       FontSize="14" Foreground="#666" Margin="0,5" TextWrapping="Wrap"/>
                            <TextBlock Text="如需查看历史记录，请使用「个人词典」功能" 
                                       FontSize="14" Foreground="#666" Margin="0,5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 进度条（隐藏，用于显示处理状态） -->
                    <ProgressBar x:Name="StatusProgressBar" Height="4" 
                                 Visibility="Collapsed" IsIndeterminate="True"
                                 Margin="0,10,0,0"/>
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- 个人词典页面（默认隐藏） -->
        <Views:VocabularyPage x:Name="VocabularyPageControl" 
                              Visibility="Collapsed"
                              BackRequested="OnVocabularyPageBackRequested"/>
    </Grid>
</Window>
