<UserControl x:Class="WordFlow.Views.VocabularyPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WordFlow.Views"
        Background="#F5F5F5">
    <UserControl.Resources>
        <local:CategoryToStringConverter x:Key="CategoryConverter"/>
        <local:SourceToStringConverter x:Key="SourceConverter"/>
        <local:ContextsToStringConverter x:Key="ContextsConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="4" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 返回按钮 -->
                <Button Grid.Column="0" x:Name="BackButton" Content="← 返回" Padding="12,6" Margin="0,0,10,0"
                        Background="#1976D2" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnBackButtonClick"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="个人词典管理" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="StatsText" Text="加载中..." FontSize="12" Foreground="#E3F2FD" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="AIButton" Content="🤖 AI分析" Padding="12,6" Margin="5,0"
                            Background="#FF9800" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="OnAIButtonClick"/>
                    <Button x:Name="LearnButton" Content="📚 智能学习" Padding="12,6" Margin="5,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="OnLearnButtonClick"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- TabControl：词典和历史记录 -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
            <!-- 词典标签页 -->
            <TabItem Header="📖 个人词典">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 词典工具栏 -->
                    <ToolBarTray Grid.Row="0" Margin="0,0,0,10">
                        <ToolBar Background="Transparent">
                            <Button x:Name="AddVocabButton" Content="➕ 添加词汇" Click="OnAddButtonClick" Padding="8,4"/>
                            <Separator/>
                            <Button x:Name="DeleteVocabButton" Content="🗑️ 删除选中" Click="OnDeleteButtonClick" Padding="8,4"/>
                            <Separator/>
                            <Button x:Name="ImportButton" Content="📥 导入" Click="OnImportButtonClick" Padding="8,4"/>
                            <Button x:Name="ExportButton" Content="📤 导出热词" Click="OnExportButtonClick" Padding="8,4"/>
                            <Separator/>
                            <Button x:Name="RefreshVocabButton" Content="🔄 刷新" Click="OnRefreshButtonClick" Padding="8,4"/>
                        </ToolBar>
                        <ToolBar Background="Transparent" HorizontalAlignment="Right">
                            <TextBox x:Name="SearchBox" Width="200" Padding="5" 
                                     TextChanged="OnSearchTextChanged" ToolTip="搜索词汇"/>
                        </ToolBar>
                    </ToolBarTray>
                    
                    <!-- 词典列表 -->
                    <DataGrid Grid.Row="1" x:Name="VocabularyDataGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FAFAFA"
                              RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="词汇" Binding="{Binding Word}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="拼音" Binding="{Binding Pinyin}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Gray"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="频率" Binding="{Binding Frequency}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="权重" Binding="{Binding Weight, StringFormat=F1}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="分类" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Category" Converter="{StaticResource CategoryConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="来源" Width="80">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Source" Converter="{StaticResource SourceConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="上下文示例" Width="*">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Contexts" Converter="{StaticResource ContextsConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="最后使用" Binding="{Binding LastUsed, StringFormat=yyyy-MM-dd}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- 历史记录标签页 -->
            <TabItem Header="📜 历史记录">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 历史记录工具栏 -->
                    <ToolBarTray Grid.Row="0" Margin="0,0,0,10">
                        <ToolBar Background="Transparent">
                            <Button x:Name="SelectAllButton" Content="☑️ 全选" Click="OnSelectAllHistoryClick" Padding="8,4"/>
                            <Button x:Name="SelectNoneButton" Content="⬜ 取消选择" Click="OnSelectNoneHistoryClick" Padding="8,4" Margin="5,0"/>
                            <Separator/>
                            <Button x:Name="TrainSelectedButton" Content="🎯 训练选中项" Click="OnTrainSelectedClick" Padding="8,4" Background="#4CAF50" Foreground="White"/>
                            <Button x:Name="AutoTrainButton" Content="🤖 自动训练全部" Click="OnAutoTrainClick" Padding="8,4" Margin="5,0" Background="#2196F3" Foreground="White"/>
                            <Separator/>
                            <Button x:Name="DeleteHistoryButton" Content="🗑️ 删除选中" Click="OnDeleteHistoryClick" Padding="8,4"/>
                        </ToolBar>
                        <ToolBar Background="Transparent" HorizontalAlignment="Right">
                            <ComboBox x:Name="HistoryFilterCombo" Width="120" Padding="5" SelectionChanged="OnHistoryFilterChanged">
                                <ComboBoxItem Content="全部记录" IsSelected="True"/>
                                <ComboBoxItem Content="今天"/>
                                <ComboBoxItem Content="最近7天"/>
                                <ComboBoxItem Content="最近30天"/>
                            </ComboBox>
                            <TextBox x:Name="HistorySearchBox" Width="180" Padding="5" Margin="5,0,0,0"
                                     TextChanged="OnHistorySearchChanged" ToolTip="搜索历史记录"/>
                        </ToolBar>
                    </ToolBarTray>
                    
                    <!-- 历史记录列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="HistoryScrollViewer">
                        <StackPanel x:Name="HistoryListPanel" Orientation="Vertical">
                            <!-- 动态生成历史记录分组 -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="ProgressText" Text=""/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
