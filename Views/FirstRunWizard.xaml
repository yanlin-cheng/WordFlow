<infrastructure:LocalizedWindow x:Class="WordFlow.Views.FirstRunWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WordFlow.Resources.Strings"
        xmlns:infrastructure="clr-namespace:WordFlow.Infrastructure"
        Title="{x:Static res:Strings.FirstRunWizard_Title}" 
        Height="620" 
        Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F9FA">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 欢迎标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="{x:Static res:Strings.FirstRunWizard_WelcomeTitle}" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#333333"/>
            <TextBlock Text="{x:Static res:Strings.FirstRunWizard_WelcomeSubtitle}" 
                       FontSize="13"
                       Foreground="#666666"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 内容区域 - 卡片式展示 -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="30" 
                BorderBrush="#E0E0E0" BorderThickness="1"
                PreviewMouseWheel="ContentArea_PreviewMouseWheel">
            <Grid>
                <!-- 卡片 1：快速设置与节省时间 -->
                <Border x:Name="Card1" Visibility="Collapsed" Background="Transparent">
                    <StackPanel>
                        <!-- 节省时间估算 -->
                        <Border Background="#FFF8E1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card1_EfficiencyTitle}" FontSize="16" FontWeight="Bold" Foreground="#FF8F00" Margin="0,0,0,10"/>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card1_EfficiencyText}" FontSize="14" Foreground="#555555" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card1_EfficiencyHint}" FontSize="12" Foreground="#777777" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 快速开始指南 -->
                        <Border Background="#F5F5F5" CornerRadius="10" Padding="25">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card1_QuickStartTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#555555" LineHeight="26">
                                    <Run FontWeight="SemiBold" Foreground="#333333" Text="1. "/><Run Text="{x:Static res:Strings.Wizard_Card1_Step1}"/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="#333333" Text="2. "/><Run Text="{x:Static res:Strings.Wizard_Card1_Step2}"/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="#333333" Text="3. "/><Run Text="{x:Static res:Strings.Wizard_Card1_Step3}"/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="#333333" Text="4. "/><Run Text="{x:Static res:Strings.Wizard_Card1_Step4}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="{x:Static res:Strings.Wizard_Card1_NextHint}" 
                                   FontSize="12" 
                                   Foreground="#999999" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 卡片 2：语音输入 -->
                <Border x:Name="Card2" Visibility="Collapsed" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0078D4" CornerRadius="50" Width="70" Height="70">
                            <TextBlock Text="🎤" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Wizard_Card2_Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#555555" LineHeight="24">
                                <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Card2_Step1}"/><LineBreak/>
                                <Run Text="    "/><Run Text="{x:Static res:Strings.Wizard_Card2_Step1Detail}"/><LineBreak/>
                                <Run Text="    "/><Run Text="{x:Static res:Strings.Wizard_Card2_Step1Alt}"/><LineBreak/>
                                <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Card2_Step2}"/><LineBreak/>
                                <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Card2_Step3}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 卡片 3：下载模型提示 -->
                <Border x:Name="Card3" Visibility="Collapsed" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FF5722" CornerRadius="50" Width="70" Height="70">
                            <TextBlock Text="💡" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Wizard_Card6_Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#555555" LineHeight="24">
                                <Run FontWeight="Bold" Foreground="#FF5722" Text="{x:Static res:Strings.Wizard_Card6_Important}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card6_Text1}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card6_Recommend}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card6_MultiLang}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card6_ButtonHint}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 卡片 4：热键设置 -->
                <Border x:Name="Card4" Visibility="Collapsed" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FF9800" CornerRadius="50" Width="70" Height="70">
                            <TextBlock Text="⌨️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Wizard_Card3_Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#555555" LineHeight="24">
                                <Run Text="{x:Static res:Strings.Wizard_Card3_Item1}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card3_Item1Detail}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card3_Item2}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card3_Item3}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card3_Item4}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 卡片 5：设置方法 -->
                <Border x:Name="Card5" Visibility="Collapsed" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#4CAF50" CornerRadius="50" Width="70" Height="70">
                            <TextBlock Text="⚙️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Wizard_Card4_Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#555555" LineHeight="24">
                                <Run Text="{x:Static res:Strings.Wizard_Card4_Item1}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card4_Item2}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card4_Item3}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card4_Item4}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 卡片 6：个人词库 -->
                <Border x:Name="Card6" Visibility="Collapsed" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#9C27B0" CornerRadius="50" Width="70" Height="70">
                            <TextBlock Text="📚" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Wizard_Card5_Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#555555" LineHeight="24">
                                <Run Text="{x:Static res:Strings.Wizard_Card5_Item1}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card5_Item2}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card5_Item3}"/><LineBreak/>
                                <Run Text="{x:Static res:Strings.Wizard_Card5_Item4}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 卡片 7：模型管理器 - 带下载进度 UI -->
                <Border x:Name="Card7" Visibility="Collapsed" Background="Transparent">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                        <!-- 顶部图标和标题 - 缩小图标 -->
                        <Border Background="#FFF3E0" CornerRadius="50" Width="80" Height="80" Margin="0,0,0,15" HorizontalAlignment="Center">
                            <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{x:Static res:Strings.Wizard_Card6_Title}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="#333333"/>
                        <TextBlock Text="{x:Static res:Strings.Wizard_Card6_Text1}" 
                                   FontSize="13" Foreground="#666666" 
                                   HorizontalAlignment="Center" Margin="0,0,0,12"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        
                        <!-- 推荐模型信息框 -->
                        <Border Background="#FFF8E1" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#FFE0B2" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card6_Recommend}" 
                                           FontSize="13" Foreground="#E65100" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card6_MultiLang}" 
                                           FontSize="12" Foreground="#FF6F00"/>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Card6_LanguagesList}" 
                                           FontSize="12" Foreground="#FF6F00" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 下载状态和进度 -->
                        <StackPanel x:Name="DownloadPanel" Visibility="Visible" Margin="0,0,0,0">
                            <!-- 下载状态 -->
                            <TextBlock x:Name="DownloadStatusText" 
                                       Text="{x:Static res:Strings.Wizard_ModelDownloading}" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="#FF5722" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"
                                       Visibility="Collapsed"/>
                            
                            <!-- 进度条 -->
                            <Border Background="#E0E0E0" CornerRadius="10" Height="20" Margin="0,0,0,8">
                                <ProgressBar x:Name="DownloadProgressBar" 
                                             Height="20" 
                                             Minimum="0" 
                                             Maximum="100"
                                             Value="0"
                                             Visibility="Visible"
                                             Margin="0"
                                             BorderThickness="0"/>
                            </Border>
                            
                            <!-- 进度百分比 -->
                            <TextBlock x:Name="DownloadProgressText" 
                                       FontSize="13" 
                                       FontWeight="Bold"
                                       Foreground="#1976D2" 
                                       HorizontalAlignment="Center"
                                       Visibility="Visible"
                                       Margin="0,0,0,12"/>
                            
                            <!-- 下载完成提示 -->
                            <TextBlock x:Name="DownloadCompleteText" 
                                       Text="{x:Static res:Strings.Wizard_DownloadComplete}" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       Foreground="#4CAF50" 
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,12"/>
                            
                            <!-- 主下载按钮 - 使用标准样式确保显示 -->
                            <Button x:Name="BackgroundDownloadButton" 
                                    Click="BackgroundDownloadButton_Click"
                                    Content="{x:Static res:Strings.Wizard_StartDownloadButton}"
                                    Padding="30,14"
                                    Height="48"
                                    MinWidth="240"
                                    Margin="0,8,0,12"
                                    Visibility="Visible"
                                    HorizontalAlignment="Center"
                                    Background="#FF5722"
                                    Foreground="White"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="8" 
                                                            Padding="{TemplateBinding Padding}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#F4511E"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#E64A19"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- 取消下载按钮 -->
                            <Button x:Name="CancelDownloadButton" 
                                    Content="{x:Static res:Strings.Wizard_CancelDownloadButton}" 
                                    Click="CancelDownloadButton_Click"
                                    Padding="25,12"
                                    MinWidth="140"
                                    Margin="0,0,0,12"
                                    Background="#E0E0E0"
                                    Foreground="#424242"
                                    FontSize="13"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="6" 
                                                            Padding="{TemplateBinding Padding}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- 提示文字 -->
                            <TextBlock x:Name="ProgressHintText" 
                                       Text="{x:Static res:Strings.Wizard_ProgressNetworkHint}" 
                                       FontSize="11" 
                                       Foreground="#9E9E9E" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,3,0,0"
                                       Visibility="Collapsed"/>
                            
                            <TextBlock x:Name="ClickNextHint" 
                                       Text="{x:Static res:Strings.Wizard_DownloadCompleteHint}"
                                       FontSize="12" 
                                       Foreground="#4CAF50" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" 
                                       Margin="0,10,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 完成页面 -->
                <Border x:Name="CompleteCard" Visibility="Collapsed" Background="Transparent">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#E8F5E9" CornerRadius="50" Width="80" Height="80" Margin="0,0,0,20">
                            <TextBlock Text="✅" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{x:Static res:Strings.Wizard_Complete_Title}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="ModelStatusText"
                                   Text="{x:Static res:Strings.Wizard_Complete_ModelStatus}" 
                                   FontSize="13" Foreground="#666666" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <Border Background="#F5F5F5" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Wizard_Complete_RememberTitle}" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#555555" LineHeight="20">
                                    <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Complete_Step1}"/><LineBreak/>
                                    <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Complete_Step2}"/><LineBreak/>
                                    <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Complete_Step3}"/><LineBreak/>
                                    <Run FontWeight="SemiBold" Text="{x:Static res:Strings.Wizard_Complete_Step4}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 卡片指示器 -->
        <StackPanel x:Name="CardIndicators" Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15,0,15">
            <!-- 由代码动态生成 -->
        </StackPanel>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BackButton" 
                    Content="{x:Static res:Strings.Wizard_BackButton}" 
                    Click="BackButton_Click"
                    Padding="18,10" 
                    Margin="0,0,10,0"
                    Visibility="Collapsed"/>
            
            <Button x:Name="NextButton" 
                    Content="{x:Static res:Strings.Wizard_NextButton}" 
                    Click="NextButton_Click"
                    Padding="18,10"
                    IsDefault="True"/>
            
            <Button x:Name="ModelManagerButton" 
                    Content="{x:Static res:Strings.Wizard_ModelManagerButton}" 
                    Click="ModelManagerButton_Click"
                    Padding="18,10"
                    Margin="10,0,0,0"
                    Visibility="Collapsed"
                    Background="#FF5722"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</infrastructure:LocalizedWindow>
