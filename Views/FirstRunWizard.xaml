<Window x:Class="WordFlow.Views.FirstRunWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordFlow 首次运行设置" 
        Height="600" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Closing="Window_Closing">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 欢迎标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="欢迎使用 WordFlow！" 
                       FontSize="22" 
                       FontWeight="Bold"/>
            <TextBlock Text="首次使用需要完成环境配置，请按照向导完成设置。" 
                       FontSize="13"
                       Foreground="Gray"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 步骤指示器 -->
        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="Step1Indicator" Background="#4CAF50" CornerRadius="10" Width="24" Height="24">
                    <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontWeight="Bold" Foreground="White" FontSize="12"/>
                </Border>
                <TextBlock Text="环境检测" VerticalAlignment="Center" Margin="10,0,20,0" FontWeight="Bold"/>
                
                <Border x:Name="Step2Indicator" Background="#E0E0E0" CornerRadius="10" Width="24" Height="24">
                    <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontWeight="Bold" Foreground="#666" FontSize="12"/>
                </Border>
                <TextBlock Text="模型下载" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- 环境检测 -->
        <GroupBox x:Name="EnvironmentGroupBox" Header="环境检测" Grid.Row="2" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- .NET 环境 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
                    <TextBlock x:Name="DotNetStatusIcon" Text="●" FontSize="16" 
                               Foreground="Orange" Width="20"/>
                    <TextBlock x:Name="DotNetStatusText" Text="正在检测 .NET 环境..." 
                               Margin="10,0" VerticalAlignment="Center"/>
                    <Button x:Name="InstallDotNetButton" Content="下载安装" 
                            Click="InstallDotNetButton_Click"
                            Padding="15,5" Margin="10,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>
                
                <!-- Python 环境 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
                    <TextBlock x:Name="PythonStatusIcon" Text="●" FontSize="16" 
                               Foreground="Green" Width="20"/>
                    <TextBlock x:Name="PythonStatusText" Text="Python 环境：已就绪" 
                               Margin="10,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 进度条 -->
                <ProgressBar x:Name="EnvironmentProgressBar" 
                             Grid.Row="2"
                             Height="8"
                             IsIndeterminate="True"
                             Margin="0,10,0,0"
                             Visibility="Visible"/>
            </Grid>
        </GroupBox>

        <!-- 模型选择 -->
        <GroupBox x:Name="ModelGroupBox" Header="选择模型" Grid.Row="3" Padding="10" Margin="0,0,0,15" IsEnabled="False">
            <StackPanel>
                <ComboBox x:Name="ModelComboBox" 
                          Padding="8,5"
                          FontSize="13"
                          Height="30"
                          SelectionChanged="ModelComboBox_SelectionChanged"/>
                <TextBlock x:Name="ModelDescriptionText" 
                           Text="请先完成环境检测"
                           Foreground="Gray" 
                           FontSize="12"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- 下载进度区域 -->
        <GroupBox x:Name="DownloadGroupBox" Header="下载进度" Grid.Row="4" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 进度条 -->
                <ProgressBar x:Name="DownloadProgressBar" 
                             Grid.Row="0"
                             Height="25"
                             Minimum="0" 
                             Maximum="100"
                             Margin="0,0,0,10"/>

                <!-- 进度信息 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock x:Name="ProgressPercentText" 
                               Text="0%"
                               FontWeight="Bold"
                               Width="50"/>
                    <TextBlock x:Name="ProgressSizeText" 
                               Text="0 MB / 0 MB"
                               Width="120"/>
                    <TextBlock x:Name="ProgressSpeedText" 
                               Text=""
                               Width="100"/>
                    <TextBlock x:Name="ProgressTimeText" 
                               Text="剩余时间：--"/>
                </StackPanel>

                <!-- 状态文本 -->
                <TextBlock x:Name="StatusText" 
                           Grid.Row="2"
                           Text='点击"开始下载"按钮开始下载模型'
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 使用镜像选项 -->
        <CheckBox x:Name="UseMirrorCheckBox" 
                  Grid.Row="5"
                  Content="使用国内镜像加速下载（推荐）"
                  IsChecked="True"
                  Margin="0,0,0,15"/>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="DownloadButton" 
                    Content="开始下载" 
                    Click="DownloadButton_Click"
                    Padding="25,10" 
                    Margin="0,0,10,0"
                    IsDefault="True"/>
            <Button x:Name="CancelButton" 
                    Content="取消" 
                    Click="CancelButton_Click"
                    Padding="25,10"
                    IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
