<Window x:Class="WordFlow.Views.RecordingIndicatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="200"
        Height="80"
        ResizeMode="NoResize">
    <Border Background="#CC000000" 
            CornerRadius="8" 
            BorderBrush="#FF444444" 
            BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 标题 -->
            <TextBlock Grid.Row="0" 
                       Text="正在录音..." 
                       Foreground="White" 
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>
            
            <!-- 波形显示区域 -->
            <Canvas Grid.Row="1" x:Name="WaveformCanvas" Background="Transparent">
                <!-- 中间的基准线 -->
                <Line x:Name="BaseLine"
                      Stroke="#444444" 
                      StrokeThickness="1"
                      X1="0" Y1="25" 
                      X2="180" Y2="25"/>
                
                <!-- 动态波形条 -->
                <Rectangle x:Name="WaveBar"
                           Fill="#FF4444"
                           Width="4"
                           Height="4"
                           RadiusX="2"
                           RadiusY="2"
                           Canvas.Left="88"
                           Canvas.Top="23"/>
                
                <!-- 多个波形条，形成效果 -->
                <Rectangle x:Name="WaveBarLeft1" Fill="#FF6666" Width="3" Height="3" RadiusX="1.5" RadiusY="1.5" Canvas.Left="80" Canvas.Top="23.5" Opacity="0.7"/>
                <Rectangle x:Name="WaveBarLeft2" Fill="#FF8888" Width="2" Height="2" RadiusX="1" RadiusY="1" Canvas.Left="72" Canvas.Top="24" Opacity="0.5"/>
                <Rectangle x:Name="WaveBarRight1" Fill="#FF6666" Width="3" Height="3" RadiusX="1.5" RadiusY="1.5" Canvas.Left="97" Canvas.Top="23.5" Opacity="0.7"/>
                <Rectangle x:Name="WaveBarRight2" Fill="#FF8888" Width="2" Height="2" RadiusX="1" RadiusY="1" Canvas.Left="106" Canvas.Top="24" Opacity="0.5"/>
            </Canvas>
        </Grid>
    </Border>
</Window>
