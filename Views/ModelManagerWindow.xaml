<infrastructure:LocalizedWindow x:Class="WordFlow.Views.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WordFlow.Resources.Strings"
        xmlns:infrastructure="clr-namespace:WordFlow.Infrastructure"
        Title="{x:Static res:Strings.ModelManager_Title}" 
        infrastructure:LocalizeExtension.ResourceKey="ModelManager_Title"
        Height="550" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="650" MinHeight="450"
        Background="#F5F5F5">
    
    <infrastructure:LocalizedWindow.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </infrastructure:LocalizedWindow.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="{x:Static res:Strings.ModelManager_Title}" 
                   FontSize="20" 
                   FontWeight="SemiBold"
                   Foreground="#333333"
                   Margin="0,0,0,5"
                   infrastructure:LocalizeExtension.ResourceKey="ModelManager_Title"/>
        
        <TextBlock Grid.Row="1" 
                   Text="{x:Static res:Strings.ModelManager_Subtitle}"
                   Foreground="#666666"
                   Margin="0,0,0,15"
                   infrastructure:LocalizeExtension.ResourceKey="ModelManager_Subtitle"/>
        
        <!-- 模型列表 - 卡片式布局 -->
        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <!-- 加载提示 -->
                <StackPanel x:Name="LoadingPanel" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="⏳" 
                               FontSize="32" 
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoadingText"
                               Text="正在检测模型..."
                               FontSize="14"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
                
                <!-- 模型列表 -->
                <ScrollViewer x:Name="ModelListScroll" 
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <StackPanel x:Name="ModelListPanel" Margin="10">
                        <!-- 动态生成模型项 -->
                    </StackPanel>
                </ScrollViewer>
                
                <!-- 空状态提示 -->
                <StackPanel x:Name="EmptyPanel" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="📭" 
                               FontSize="32" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="暂无可用模型"
                               FontSize="14"
                               Foreground="#999999"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 下载进度区域 -->
        <Border Grid.Row="3" 
                Background="#F9F9F9" 
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15"
                Margin="0,15,0,0" 
                x:Name="DownloadProgressGrid"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 进度条 -->
                <ProgressBar Grid.Row="0" 
                             x:Name="DownloadProgressBar"
                             Height="10"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Background="#E0E0E0"
                             Foreground="#0078D4"
                             BorderThickness="0"/>
                
                <!-- 状态文本和百分比 -->
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="DownloadStatusText" 
                               Text="{x:Static res:Strings.ModelManager_DownloadProgress}" 
                               Foreground="#555555"
                               FontWeight="Medium"
                               infrastructure:LocalizeExtension.ResourceKey="ModelManager_DownloadProgress"/>
                    <TextBlock Grid.Column="1" x:Name="DownloadProgressText" 
                               Text="0%" 
                               Foreground="#0078D4" 
                               FontWeight="Bold"
                               FontSize="13"/>
                </Grid>
                
                <!-- 取消下载按钮 -->
                <Button Grid.Row="2"
                        x:Name="BackgroundDownloadButton"
                        Content="⏹️ 取消下载"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Click="BackgroundDownloadButton_Click"/>
            </Grid>
        </Border>
        
        <!-- 按钮区域 -->
        <Grid Grid.Row="4" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：查看日志按钮 -->
            <Button x:Name="ViewLogsButton"
                    Content="📄 查看日志"
                    Style="{StaticResource SecondaryButton}"
                    Click="ViewLogsButton_Click"
                    Grid.Column="0"/>
            
            <!-- 右侧：刷新和关闭按钮 -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button x:Name="RefreshButton"
                        Content="{x:Static res:Strings.ModelManager_RefreshButton}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        Click="RefreshButton_Click"
                        infrastructure:LocalizeExtension.ResourceKey="ModelManager_RefreshButton"/>
                
                <Button Content="{x:Static res:Strings.ModelManager_CloseButton2}"
                        Style="{StaticResource PrimaryButton}"
                        Click="CloseButton_Click"
                        infrastructure:LocalizeExtension.ResourceKey="ModelManager_CloseButton2"/>
            </StackPanel>
        </Grid>
    </Grid>
</infrastructure:LocalizedWindow>
