<infrastructure:LocalizedWindow x:Class="WordFlow.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WordFlow.Resources.Strings"
        xmlns:infrastructure="clr-namespace:WordFlow.Infrastructure"
        Title="{x:Static res:Strings.UpdateDialog_Title}"
        infrastructure:LocalizeExtension.ResourceKey="UpdateDialog_Title"
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="📦 WordFlow 新版本可用" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       Foreground="#333333"/>
            <TextBlock x:Name="VersionText" 
                       Text="v2.1.0" 
                       FontSize="14"
                       Foreground="#666666"
                       Margin="0,5,0,0"/>
            <TextBlock x:Name="ReleaseDateText" 
                       Text="发布日期：2026-03-15" 
                       FontSize="12"
                       Foreground="#999999"
                       Margin="0,3,0,0"/>
        </StackPanel>
        
        <!-- 更新内容列表 -->
        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="250">
                <StackPanel x:Name="ChangesList" Margin="15">
                    <!-- 动态生成变更项 -->
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- 下载进度区域 -->
        <Border Grid.Row="3" 
                x:Name="ProgressBorder"
                Background="White" 
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15"
                Visibility="Collapsed">
            <StackPanel>
                <ProgressBar x:Name="DownloadProgressBar"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Background="#E0E0E0"
                             Foreground="#0078D4"
                             BorderThickness="0"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressText" 
                               Text="0%" 
                               Foreground="#0078D4" 
                               FontWeight="Medium"/>
                    <TextBlock x:Name="SpeedText" 
                               Grid.Column="1"
                               Text="" 
                               Foreground="#666666" 
                               FontSize="12"/>
                </Grid>
                <TextBlock x:Name="RemainingTimeText" 
                           Text="" 
                           Foreground="#666666" 
                           FontSize="11"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 紧急更新提示 -->
        <Border Grid.Row="4" 
                x:Name="UrgentBorder"
                Background="#FFF3E0" 
                BorderBrush="#FFB74D"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,15"
                Visibility="Collapsed">
            <TextBlock Text="⚠️ 此更新为重要安全更新，建议尽快安装" 
                       Foreground="#E65100"
                       FontSize="12"/>
        </Border>
        
        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button x:Name="SkipButton"
                    Content="{x:Static res:Strings.UpdateDialog_SkipButton}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"
                    Padding="20,10"
                    Click="SkipButton_Click"
                    infrastructure:LocalizeExtension.ResourceKey="UpdateDialog_SkipButton"/>
            
            <Button x:Name="LaterButton"
                    Content="{x:Static res:Strings.UpdateDialog_LaterButton}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"
                    Padding="20,10"
                    Click="LaterButton_Click"
                    infrastructure:LocalizeExtension.ResourceKey="UpdateDialog_LaterButton"/>
            
            <Button x:Name="UpdateButton"
                    Content="{x:Static res:Strings.UpdateDialog_UpdateButton}"
                    Style="{StaticResource PrimaryButton}"
                    Padding="20,10"
                    Click="UpdateButton_Click"
                    infrastructure:LocalizeExtension.ResourceKey="UpdateDialog_UpdateButton"/>
        </StackPanel>
    </Grid>
    
    <infrastructure:LocalizedWindow.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </infrastructure:LocalizedWindow.Resources>
</infrastructure:LocalizedWindow>
