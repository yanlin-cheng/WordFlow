<infrastructure:LocalizedWindow x:Class="WordFlow.Views.VocabularyManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:WordFlow.Resources.Strings"
        xmlns:local="clr-namespace:WordFlow.Views"
        xmlns:infrastructure="clr-namespace:WordFlow.Infrastructure"
        Title="{x:Static res:Strings.VocabularyManager_Title}" 
        infrastructure:LocalizeExtension.ResourceKey="VocabularyManager_Title"
        Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <infrastructure:LocalizedWindow.Resources>
        <local:CategoryToStringConverter x:Key="CategoryConverter"/>
        <local:SourceToStringConverter x:Key="SourceConverter"/>
        <local:ContextsToStringConverter x:Key="ContextsConverter"/>
    </infrastructure:LocalizedWindow.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="4" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Static res:Strings.VocabularyManager_Title}" FontSize="18" FontWeight="Bold" Foreground="White"
                               infrastructure:LocalizeExtension.ResourceKey="VocabularyManager_Title"/>
                    <TextBlock x:Name="StatsText" Text="{x:Static res:Strings.VocabManager_Stats_Loading}" FontSize="12" Foreground="#E3F2FD" Margin="0,5,0,0"
                               infrastructure:LocalizeExtension.ResourceKey="VocabManager_Stats_Loading"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="AIButton" Content="{x:Static res:Strings.VocabManager_AI_Button}" Padding="12,6" Margin="5,0"
                            Background="#FF9800" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="OnAIButtonClick"
                            infrastructure:LocalizeExtension.ResourceKey="VocabManager_AI_Button"/>
                    <Button x:Name="LearnButton" Content="{x:Static res:Strings.VocabManager_Learn_Button}" Padding="12,6" Margin="5,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="OnLearnButtonClick"
                            infrastructure:LocalizeExtension.ResourceKey="VocabManager_Learn_Button"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- TabControl：词典和历史记录 -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
            <!-- 词典标签页 -->
            <TabItem Header="{x:Static res:Strings.VocabularyManager_Title}"
                     infrastructure:LocalizeExtension.ResourceKey="VocabularyManager_Title">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 词典工具栏 -->
                    <ToolBarTray Grid.Row="0" Margin="0,0,0,10">
                        <ToolBar Background="Transparent">
                            <Button x:Name="AddVocabButton" Content="{x:Static res:Strings.VocabManager_Toolbar_Add}" Click="OnAddButtonClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_Toolbar_Add"/>
                            <Separator/>
                            <Button x:Name="DeleteVocabButton" Content="{x:Static res:Strings.VocabManager_Toolbar_Delete}" Click="OnDeleteButtonClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_Toolbar_Delete"/>
                            <Separator/>
                            <Button x:Name="ImportButton" Content="{x:Static res:Strings.VocabManager_Toolbar_Import}" Click="OnImportButtonClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_Toolbar_Import"/>
                            <Button x:Name="ExportButton" Content="{x:Static res:Strings.VocabManager_Toolbar_Export}" Click="OnExportButtonClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_Toolbar_Export"/>
                            <Separator/>
                            <Button x:Name="RefreshVocabButton" Content="{x:Static res:Strings.VocabManager_Toolbar_Refresh}" Click="OnRefreshButtonClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_Toolbar_Refresh"/>
                        </ToolBar>
                        <ToolBar Background="Transparent" HorizontalAlignment="Right">
                            <TextBox x:Name="SearchBox" Width="200" Padding="5" 
                                     TextChanged="OnSearchTextChanged" ToolTip="{x:Static res:Strings.VocabManager_SearchBox_Tooltip}"
                                     infrastructure:LocalizeExtension.ResourceKey="VocabManager_SearchBox_Tooltip"/>
                        </ToolBar>
                    </ToolBarTray>
                    
                    <!-- 词典列表 -->
                    <DataGrid Grid.Row="1" x:Name="VocabularyDataGrid" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FAFAFA"
                              RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Word}" Binding="{Binding Word}" Width="150"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Word">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Pinyin}" Binding="{Binding Pinyin}" Width="120"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Pinyin">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Gray"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Frequency}" Binding="{Binding Frequency}" Width="60"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Frequency">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Weight}" Binding="{Binding Weight, StringFormat=F1}" Width="60"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Weight">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Category}" Width="90"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Category">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Category" Converter="{StaticResource CategoryConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Source}" Width="80"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Source">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Source" Converter="{StaticResource SourceConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_Contexts}" Width="*"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_Contexts">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Contexts" Converter="{StaticResource ContextsConverter}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static res:Strings.VocabManager_Column_LastUsed}" Binding="{Binding LastUsed, StringFormat=yyyy-MM-dd}" Width="90"
                                                infrastructure:LocalizeExtension.ResourceKey="VocabManager_Column_LastUsed"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- 历史记录标签页 -->
            <TabItem Header="{x:Static res:Strings.VocabManager_HistoryTab}"
                     infrastructure:LocalizeExtension.ResourceKey="VocabManager_HistoryTab">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 历史记录工具栏 -->
                    <ToolBarTray Grid.Row="0" Margin="0,0,0,10">
                        <ToolBar Background="Transparent">
                            <Button x:Name="SelectAllButton" Content="{x:Static res:Strings.VocabManager_History_SelectAll}" Click="OnSelectAllHistoryClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_SelectAll"/>
                            <Button x:Name="SelectNoneButton" Content="{x:Static res:Strings.VocabManager_History_SelectNone}" Click="OnSelectNoneHistoryClick" Padding="8,4" Margin="5,0"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_SelectNone"/>
                            <Separator/>
                            <Button x:Name="TrainSelectedButton" Content="{x:Static res:Strings.VocabManager_History_TrainSelected}" Click="OnTrainSelectedClick" Padding="8,4" Background="#4CAF50" Foreground="White"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_TrainSelected"/>
                            <Button x:Name="AutoTrainButton" Content="{x:Static res:Strings.VocabManager_History_AutoTrain}" Click="OnAutoTrainClick" Padding="8,4" Margin="5,0" Background="#2196F3" Foreground="White"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_AutoTrain"/>
                            <Separator/>
                            <Button x:Name="DeleteHistoryButton" Content="{x:Static res:Strings.VocabManager_History_Delete}" Click="OnDeleteHistoryClick" Padding="8,4"
                                    infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_Delete"/>
                        </ToolBar>
                        <ToolBar Background="Transparent" HorizontalAlignment="Right">
                            <ComboBox x:Name="HistoryFilterCombo" Width="120" Padding="5" SelectionChanged="OnHistoryFilterChanged">
                                <ComboBoxItem Content="{x:Static res:Strings.VocabManager_History_Filter}" IsSelected="True"
                                              infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_Filter"/>
                                <ComboBoxItem Content="{x:Static res:Strings.VocabManager_History_FilterToday}"
                                              infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_FilterToday"/>
                                <ComboBoxItem Content="{x:Static res:Strings.VocabManager_History_Filter7Days}"
                                              infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_Filter7Days"/>
                                <ComboBoxItem Content="{x:Static res:Strings.VocabManager_History_Filter30Days}"
                                              infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_Filter30Days"/>
                            </ComboBox>
                            <TextBox x:Name="HistorySearchBox" Width="180" Padding="5" Margin="5,0,0,0"
                                     TextChanged="OnHistorySearchChanged" ToolTip="{x:Static res:Strings.VocabManager_History_Search_Tooltip}"
                                     infrastructure:LocalizeExtension.ResourceKey="VocabManager_History_Search_Tooltip"/>
                        </ToolBar>
                    </ToolBarTray>
                    
                    <!-- 历史记录列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="HistoryScrollViewer">
                        <StackPanel x:Name="HistoryListPanel" Orientation="Vertical">
                            <!-- 动态生成历史记录分组 -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{x:Static res:Strings.VocabManager_Status_Ready}"
                           infrastructure:LocalizeExtension.ResourceKey="VocabManager_Status_Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="ProgressText" Text=""/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</infrastructure:LocalizedWindow>
