<Window x:Class="WordFlow.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordFlow 设置" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选项卡控件 -->
        <TabControl x:Name="SettingsTabControl" Grid.Row="0">
            
            <!-- 热键设置 -->
            <TabItem Header="热键设置">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="录音热键" Grid.Row="0" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="选择录音触发键：" Margin="0,0,0,10"/>
                            <ComboBox x:Name="HotkeyComboBox" 
                                      SelectionChanged="HotkeyComboBox_SelectionChanged"
                                      Padding="8,5"/>
                            <TextBlock x:Name="HotkeyHintText" 
                                       Text="按住选中的键说话，松开后自动识别"
                                       Foreground="Gray" 
                                       FontSize="11"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="启动设置" Grid.Row="1" Padding="10">
                        <StackPanel>
                            <CheckBox x:Name="AutoStartCheckBox" 
                                      Content="开机自启动"
                                      Checked="AutoStartCheckBox_Changed"
                                      Unchecked="AutoStartCheckBox_Changed"
                                      Margin="0,5"/>
                            <CheckBox x:Name="StartMinimizedCheckBox" 
                                      Content="启动时最小化到托盘"
                                      Checked="StartMinimizedCheckBox_Changed"
                                      Unchecked="StartMinimizedCheckBox_Changed"
                                      Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 模型管理 -->
            <TabItem Header="模型管理">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="已安装模型" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="CurrentModelText" 
                                   Text="当前模型：未选择"
                                   Foreground="Green"
                                   Margin="0,0,0,10"/>
                        <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="ModelStatusText" 
                                           Text="正在检测模型..."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>
                                <Button x:Name="RefreshModelButton"
                                        Content="刷新模型状态"
                                        Padding="10,5"
                                        HorizontalAlignment="Left"
                                        Click="RefreshModelButton_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <GroupBox Header="可用模型" Grid.Row="1" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <ListBox x:Name="ModelListBox" Grid.Row="0" SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" 
                                                       Foreground="{Binding StatusColor}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="DownloadModelButton"
                                        Content="下载选中模型"
                                        Padding="15,8"
                                        HorizontalAlignment="Left"
                                        Click="DownloadModelButton_Click"/>
                                <TextBlock x:Name="DownloadProgressText" 
                                           Text="" 
                                           Margin="15,8,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <TextBlock Text="模型下载源" FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="GiteeMirrorRadio" Content="Gitee（国内推荐）" 
                                         GroupName="MirrorSource" Margin="0,0,15,0"
                                         Checked="MirrorRadio_Changed"/>
                            <RadioButton x:Name="OriginalRadio" Content="原始源" 
                                         GroupName="MirrorSource"
                                         Checked="MirrorRadio_Changed"/>
                        </StackPanel>
                        <TextBlock Text="Gitee 源位于国内服务器，下载速度更快" 
                                   FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 关于 -->
            <TabItem Header="关于">
                <Grid Margin="15">
                    <StackPanel>
                        <TextBlock Text="WordFlow - 智能语音输入工具" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="版本：1.0.0" Foreground="Gray" Margin="0,10,0,0"/>
                        <TextBlock Margin="0,10,0,0">
                            <Hyperlink NavigateUri="https://github.com/wanddream/WordFlow" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                GitHub 项目地址
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock>
                            <Hyperlink NavigateUri="https://gitee.com/cheng-yanlin/WordFlow-Release" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Gitee 发布页面
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="保存" 
                    Click="SaveButton_Click"
                    Padding="20,8" 
                    Margin="0,0,10,0"
                    IsDefault="True"/>
            <Button Content="取消" 
                    Click="CancelButton_Click"
                    Padding="20,8"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
