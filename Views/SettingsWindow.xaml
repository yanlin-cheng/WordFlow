<Window x:Class="WordFlow.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordFlow 设置" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选项卡控件 -->
        <TabControl x:Name="SettingsTabControl" Grid.Row="0">
            
            <!-- 热键设置 -->
            <TabItem Header="热键设置">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="录音热键" Grid.Row="0" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="选择录音触发键：" Margin="0,0,0,10"/>
                            <ComboBox x:Name="HotkeyComboBox" 
                                      SelectionChanged="HotkeyComboBox_SelectionChanged"
                                      Padding="8,5"/>
                            <TextBlock x:Name="HotkeyHintText" 
                                       Text="按住选中的键说话，松开后自动识别"
                                       Foreground="Gray" 
                                       FontSize="11"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="启动设置" Grid.Row="1" Padding="10">
                        <StackPanel>
                            <CheckBox x:Name="AutoStartCheckBox" 
                                      Content="开机自启动"
                                      Checked="AutoStartCheckBox_Changed"
                                      Unchecked="AutoStartCheckBox_Changed"
                                      Margin="0,5"/>
                            <CheckBox x:Name="StartMinimizedCheckBox" 
                                      Content="启动时最小化到托盘"
                                      Checked="StartMinimizedCheckBox_Changed"
                                      Unchecked="StartMinimizedCheckBox_Changed"
                                      Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 关于 -->
            <TabItem Header="关于">
                <Grid Margin="15">
                    <StackPanel>
                        <TextBlock Text="WordFlow - 智能语音输入工具" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="版本：1.0.0" Foreground="Gray" Margin="0,10,0,0"/>
                        
                        <Separator Margin="0,15,0,15"/>
                        
                        <TextBlock Text="相关链接" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Margin="0,0,0,10">
                            <Hyperlink NavigateUri="https://github.com/wanddream/WordFlow" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                GitHub 项目地址
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,10">
                            <Hyperlink NavigateUri="https://gitee.com/cheng-yanlin/WordFlow-Release" 
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Gitee 发布页面
                            </Hyperlink>
                        </TextBlock>
                        
                        <Separator Margin="0,15,0,15"/>
                        
                        <!-- 首次运行向导入口 -->
                        <TextBlock Text="工具" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Button x:Name="RunWizardButton"
                                Content="🎯 重新运行首次向导"
                                Padding="15,10"
                                HorizontalAlignment="Left"
                                Click="RunWizardButton_Click"/>
                        <TextBlock Text="查看功能介绍和下载语音模型" 
                                   FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                        
                        <Button x:Name="ManageModelButton"
                                Content="📦 模型管理"
                                Padding="15,10"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Click="ManageModelButton_Click"/>
                        <TextBlock Text="下载、切换或删除语音模型" 
                                   FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="保存" 
                    Click="SaveButton_Click"
                    Padding="20,8" 
                    Margin="0,0,10,0"
                    IsDefault="True"/>
            <Button Content="取消" 
                    Click="CancelButton_Click"
                    Padding="20,8"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
